rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isServerTimestamp(data, key) {
      return !(key in data) || (data[key] is timestamp && data[key] == request.time);
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'asartist20@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Validation helpers
    function isValidHabit(data) {
      return data.keys().hasAll(['name', 'streak', 'completed', 'ownerId']) &&
             data.name is string && data.name.size() <= 200 &&
             data.streak is int && data.streak >= 0 &&
             data.completed is bool &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'updatedAt') &&
             isServerTimestamp(data, 'createdAt') &&
             (!('reminderTime' in data) || (data.reminderTime is string && data.reminderTime.size() <= 5)) &&
             (!('soundType' in data) || (data.soundType is string && data.soundType in ['divine', 'kaching'])) &&
             (!('category' in data) || data.category is string) &&
             (!('description' in data) || data.description is string) &&
             (!('frequency' in data) || data.frequency is string);
    }

    function isValidDesire(data) {
      return data.keys().hasAll(['text', 'category', 'date', 'isAchieved', 'ownerId', 'updatedAt']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string &&
             data.isAchieved is bool &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'updatedAt');
    }

    function isValidVisionItem(data) {
      return data.keys().hasAll(['imageUrl', 'caption', 'ownerId', 'updatedAt']) &&
             data.imageUrl is string && data.imageUrl.size() <= 1000000 &&
             data.caption is string && data.caption.size() <= 1000 &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'updatedAt');
    }

    function isValidDiaryEntry(data) {
      return data.keys().hasAll(['content', 'method', 'ownerId', 'timestamp']) &&
             data.content is string && data.content.size() <= 10000 &&
             data.method in ['free', '369', '555'] &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'timestamp');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'tier']) &&
             data.email is string &&
             data.tier in ['free', 'Novice', 'Sovereign'] &&
             isServerTimestamp(data, 'updatedAt') &&
             (!('walkthroughCompleted' in data) || data.walkthroughCompleted is bool) &&
             (!('hasCompletedOnboarding' in data) || data.hasCompletedOnboarding is bool) &&
             (!('manifestationGoal' in data) || data.manifestationGoal is string) &&
             (!('onboardingAffirmation' in data) || data.onboardingAffirmation is string) &&
             (!('subscriptionExpiry' in data) || data.subscriptionExpiry is timestamp) &&
             (!('trialExpiresAt' in data) || data.trialExpiresAt is timestamp) &&
             (!('isAdmin' in data) || data.isAdmin is bool) &&
             (!('isSubscribed' in data) || data.isSubscribed is bool) &&
             (!('whatsappNumber' in data) || data.whatsappNumber is string) &&
             (!('whatsappReminders' in data) || data.whatsappReminders is bool) &&
             (!('whatsappOptOut' in data) || data.whatsappOptOut is bool) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             (!('displayName' in data) || data.displayName is string || data.displayName == null) &&
             (!('lastCheckinScore' in data) || (data.lastCheckinScore is int && data.lastCheckinScore >= 1 && data.lastCheckinScore <= 5));
    }

    function isValidCheckin(data) {
      return data.keys().hasAll(['score', 'timestamp', 'date']) &&
             data.score is int && data.score >= 1 && data.score <= 5 &&
             data.date is string && data.date.size() <= 10 &&
             isServerTimestamp(data, 'timestamp');
    }

    function isValidHabitLog(data) {
      return data.keys().hasAll(['habitId', 'ownerId', 'timestamp']) &&
             data.habitId is string &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'timestamp') &&
             (!('duration' in data) || data.duration is int) &&
             (!('intensity' in data) || (data.intensity is int && data.intensity >= 1 && data.intensity <= 10)) &&
             (!('mood' in data) || (data.mood is string && data.mood.size() <= 100));
    }

    function isValidFrequencyLog(data) {
      return data.keys().hasAll(['level', 'mood', 'date', 'ownerId', 'timestamp']) &&
             data.level is int && data.level >= 1 && data.level <= 10 &&
             data.mood is string &&
             data.date is string &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'timestamp');
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'label', 'ownerId', 'timestamp']) &&
             data.type in ['income', 'expense'] &&
             (data.amount is int || data.amount is float) &&
             data.label is string && data.label.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             isServerTimestamp(data, 'timestamp') &&
             (!('category' in data) || (data.category is string && data.category.size() <= 100));
    }

    // Collection matches
    match /users/{userId} {
      allow get: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().tier == 'free' || incoming().tier == 'Novice' || incoming().tier == 'Sovereign');
      allow update: if (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'updatedAt', 'walkthroughCompleted', 'hasCompletedOnboarding', 'manifestationGoal', 'onboardingAffirmation', 'photoURL', 'displayName', 'whatsappNumber', 'whatsappReminders', 'whatsappOptOut', 'lastCheckinScore',
          'tier', 'status', 'trialStart', 'trialEnd', 'trialExpiresAt', 'isSubscribed', 'country', 'currency', 'billingCycle', 'subscriptionExpiry', 'subscriptionStart', 'subscriptionEnd', 'isAdmin', 'createdAt'
        ])
      )) || isAdmin();
      allow delete: if isAdmin();

      match /checkins/{checkinId} {
        allow get: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
        allow list: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
        allow create, update: if (isSignedIn() && request.auth.uid == userId && isValidCheckin(incoming())) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if (isOwner(existing()) && isValidTransaction(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['label', 'amount', 'category', 'timestamp'])
      )) || (isAdmin() && isValidTransaction(incoming()));
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /habit_logs/{logId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isOwner(existing()) || isAdmin();
      allow create: if (isSignedIn() && isValidHabitLog(incoming())) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /frequency_logs/{logId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isOwner(existing()) || isAdmin();
      allow create: if (isSignedIn() && isValidFrequencyLog(incoming())) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /habits/{habitId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if (isSignedIn() && isValidHabit(incoming())) || isAdmin();
      allow update: if (isSignedIn() && isOwner(existing()) && isValidHabit(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'streak', 'updatedAt']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'reminderTime', 'soundType', 'updatedAt'])
      )) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /desires/{desireId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if (isSignedIn() && isValidDesire(incoming())) || isAdmin();
      allow update: if (isSignedIn() && isOwner(existing()) && isValidDesire(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isAchieved', 'updatedAt']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['text', 'category', 'updatedAt'])
      )) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /vision_items/{itemId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if (isSignedIn() && isValidVisionItem(incoming())) || isAdmin();
      allow update: if (isSignedIn() && isOwner(existing()) && isValidVisionItem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['caption', 'imageUrl', 'updatedAt'])
      )) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }

    match /diary_entries/{entryId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if (isSignedIn() && isValidDiaryEntry(incoming())) || isAdmin();
      allow update: if (isSignedIn() && isOwner(existing()) && isValidDiaryEntry(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['content', 'timestamp'])
      )) || isAdmin();
      allow delete: if isOwner(existing()) || isAdmin();
    }
  }
}
