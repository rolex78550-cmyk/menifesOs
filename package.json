    "express-rate-limit": "^8.5.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-schedule": "^2.1.1",
